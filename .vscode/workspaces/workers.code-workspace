{
	"folders": [
		{
			"name": "Config",
			"path": "../../"
		},
		{
			"name": "Projects",
			"path": "../../1projects"
		},
		{
			"name": "Apps",
			"path": "../../apps"
		},
		{
			"name": "Apps2",
			"path": "../../apps2"
		},
		{
			"name": "BunApps",
			"path": "../../bunapps"
		},
		{
			"name": "Docker",
			"path": "../../docker"
		},
		{
			"name": "Packages",
			"path": "../../packages"
		}
	],
	"settings": {
		"files.exclude": {
			"1projects/": true,
			"apps/": true,
			"apps2/": true,
			"bunapps/": true,
			"docker/": true,
			"packages/": true
		},

		"astro.content-intellisense": true,
		"typescript.preferences.autoImportFileExcludePatterns": ["**/vitest/dist/**"],

		"github-actions.workflows.pinned.workflows": [
			".github/workflows/release.yml",
			".github/workflows/branches.yml"
		],
		"github-actions.workflows.pinned.refresh.enabled": true,
		"github-actions.workflows.pinned.refresh.interval": 30,

		"files.associations": {
			"**/packages/tools/bin/*": "shellscript",
			"**/*.css": "tailwindcss",
			"turbo.json": "jsonc",
			"**/packages/typescript-config/*.json": "jsonc",
			"**/snippets/stylus/**/*.css": "stylus"
		}
	}
}
